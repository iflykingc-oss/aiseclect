# ========== 飞书 ==========
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Wiki 内嵌表格 —— 从你的飞书链接里读
# https://my.feishu.cn/wiki/{FEISHU_PAGE_ID}?table={FEISHU_TABLE_ID}
FEISHU_PAGE_ID=
FEISHU_TABLE_ID=
FEISHU_DOMAIN=my.feishu.cn
# 独立表格（用 FEISHU_APP_TOKEN 替代 FEISHU_PAGE_ID；跑命令时加 --no-wiki）
# FEISHU_APP_TOKEN=bascnxxxxxxxxxxxxxxxxxxxxxxxx

# ========== LLM（默认火山方舟 Plan）==========
# Plan 端点支持 ark-code-latest / ark-doubao-pro 等模型
OPENAI_API_KEY=ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
OPENAI_MODEL=ark-code-latest

# 备选（非 Plan 端点）：
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_MODEL=doubao-seed-1-6-250615

# 其他 OpenAI 兼容服务（DeepSeek / OpenAI / Moonshot 等）：
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ========== Tavily ==========
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# ========== 可选 ==========
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# AISECLECT_OUTPUT_DIR=output
# LOG_LEVEL=INFO
